<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.com.brorder.order.mapper.OrderMenuMapper">

    <!-- =========================
         ORDER MENU INSERT
         ========================= -->
    <insert id="insert">
        INSERT INTO order_menu(
            order_id,
            menu_id,
            option_id,
            price
        )
        VALUES(
                  #{orderId},
                  #{menuId},
                  #{optionId},
                  #{price}
              )
    </insert>

</mapper>